# LifeOS Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or production secrets.

# =============================================================================
# Public (safe for client bundles)
# =============================================================================

# Canonical application origin used for OAuth redirects and absolute links.
# Local development: http://localhost:3000
# Production: https://YOUR-PRODUCTION-DOMAIN (HTTPS required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL from Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key from Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# =============================================================================
# Server-only secrets — never expose to the client
# =============================================================================

# Supabase service role key — cron jobs and push delivery only (not browser code)
SUPABASE_SERVICE_ROLE_KEY=

# Single allowed login email (case-insensitive exact match)
APP_ALLOWED_EMAIL=

# =============================================================================
# Canvas ICS (required for Canvas connect and sync)
# =============================================================================

# Base64-encoded 32-byte AES key for encrypting Canvas feed URLs at rest.
# Generate in PowerShell:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
TOKEN_ENCRYPTION_KEY=

# Comma-separated Canvas hostnames allowed for ICS fetch (no default).
# Example: k-state.instructure.com
CANVAS_ALLOWED_HOSTNAMES=

# =============================================================================
# Cron (required for scheduled Canvas sync and notifications)
# =============================================================================

# Bearer token for POST /api/cron/* and GET /api/readiness.
# Generate in PowerShell:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
CRON_SECRET=

# =============================================================================
# Web Push (required to enable notifications)
# =============================================================================

# Browser-safe VAPID public key (also used server-side for delivery)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Server-only VAPID private key — never expose to the client
VAPID_PRIVATE_KEY=

# VAPID subject — typically mailto:you@example.com
VAPID_SUBJECT=mailto:you@example.com

# Generate VAPID keys (after npm install):
# npx web-push generate-vapid-keys

# =============================================================================
# Microsoft 365 calendar (disabled by default)
# =============================================================================

# Set to true only when Entra app registration is complete.
# Keep false for production until Microsoft integration is intentionally enabled.
MICROSOFT_INTEGRATION_ENABLED=false

# Required only when MICROSOFT_INTEGRATION_ENABLED=true:
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Use "organizations" for any work/school account, or a specific tenant ID
MICROSOFT_TENANT_ID=organizations
# Must exactly match the redirect URI in your Entra app registration
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# =============================================================================
# Production example (do not uncomment with real values in version control)
# =============================================================================
# NEXT_PUBLIC_APP_URL=https://YOUR-PRODUCTION-DOMAIN
# MICROSOFT_REDIRECT_URI=https://YOUR-PRODUCTION-DOMAIN/api/auth/microsoft/callback
